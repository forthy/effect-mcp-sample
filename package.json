{
  "name": "effect-mcp-sample",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "effect-mcp-sample": "dist/index.js"
  },
  "scripts": {
    "compile": "bun build ./src/index.ts --compile --outfile greeting-mcp; chmod +x greeting-mcp",
    "build": "tsc",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "start": "bun src/index.js",
    "dev": "bun src/index.ts",
    "prepare": "effect-language-service patch",
    "mcp:inspector": "bunx @modelcontextprotocol/inspector"
  },
  "devDependencies": {
    "@effect/language-service": "^0.80.0",
    "@effect/vitest": "^0.27.0",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "3.2.4",
    "typescript": "^5.2.2"
  },
  "dependencies": {
    "@effect/cli": "^0.73.2",
    "@effect/platform": "^0.94.5",
    "@effect/platform-bun": "^0.89.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@types/bun": "^1.3.10",
    "@zod-plugin/effect": "^0.1.0",
    "effect": "^3.19.19",
    "effect-mcp": "^0.1.16",
    "express": "^5.2.1"
  }
}
